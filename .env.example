# Stripe (get keys from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
# Required for confirming payments and sending emails (Stripe CLI: stripe listen --forward-to localhost:3000/api/webhooks/stripe)
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (https://resend.com) — confirmation and studio notification emails
RESEND_API_KEY=re_...

# Public Google Sheets CSV used by /calendario for class schedule rows.
# Expected columns: date, day, time, class_name, capacity, active
GOOGLE_SHEET_CSV_URL=https://docs.google.com/spreadsheets/d/e/2PACX-.../pub?gid=0&single=true&output=csv
